{
  "providers": [
    {
      "name": "default",
      "api_base": "http://127.0.0.1:11000/v1",
      "api_key": "",
      "model": "deepseek-v4-flash",
      "reasoning_effort": "high",
      "context_limit": 300000
    }
  ],
  "mcp_servers": [
    {
      "name": "filesystem",
      "transport": "stdio",
      "command": "docker",
      "args": [
        "exec", "-i", "cima-mcp-test",
        "npx", "-y", "@modelcontextprotocol/server-filesystem",
        "/tmp/test-files"
      ],
      "timeout_sec": 30
    }
  ]
}
